{
  "name": "requiem",
  "version": "1.0.8",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "concurrently -k \"vite --mode production\" \"npm run dev:electron\"",
    "postinstall": "electron-builder install-app-deps",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -b tsconfig.node.json --force && electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:web": "vite --config vite.config.web.ts",
    "build:vite": "vite build",
    "build:vite:dev": "vite build --mode development",
    "build:electron": "tsc -b tsconfig.node.json --force",
    "build:web": "cross-env CAPACITOR_BUILD=true vite build --config vite.config.web.ts",
    "build:web:dev": "cross-env CAPACITOR_BUILD=true vite build --mode development --config vite.config.web.ts",
    "preview:web": "vite preview --config vite.config.web.ts",
    "cap:sync": "cross-env CAPACITOR_ENV=production npm run build:web && cross-env CAPACITOR_ENV=production npx cap sync",
    "cap:sync:dev": "cross-env CAPACITOR_ENV=development npm run build:web:dev && cross-env CAPACITOR_ENV=development npx cap sync",
    "cap:open": "npx cap open android",
    "build": "npm run build:vite && npm run build:electron && electron-builder",
    "build:dev": "npm run build:vite:dev && npm run build:electron && electron-builder",
    "dist": "node scripts/build.js",
    "apk": "node scripts/build.js apk",
    "apk:dev": "node scripts/build.js apk dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItMeMario/Requiem.git"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dompurify": "^3.4.10",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capawesome/capacitor-google-sign-in": "^0.1.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "firebase": "^12.14.0",
    "firebase-tools": "^15.22.4",
    "idb": "^8.0.3",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.4",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.mario.requiem",
    "productName": "Requiem",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ItMeMario",
        "repo": "Requiem"
      }
    ],
    "nsis": {
      "include": "src/build/installer.nsh",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "directories": {
      "buildResources": "src/build",
      "output": "dist/desktop"
    },
    "files": [
      "dist/**/*",
      "!dist/desktop",
      "!dist/mobile",
      "package.json"
    ],
    "win": {
      "icon": "src/build/icon.ico"
    },
    "mac": {
      "icon": "src/build/icon.icns"
    },
    "linux": {
      "icon": "src/build/icon.png"
    }
  }
}