{
  "name": "requiem",
  "version": "1.0.1",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -b tsconfig.node.json --force && electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:web": "vite --config vite.config.web.ts",
    "build:vite": "vite build",
    "build:electron": "tsc -b tsconfig.node.json --force",
    "build:web": "vite build --config vite.config.web.ts",
    "preview:web": "vite preview --config vite.config.web.ts",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:open": "npx cap open android",
    "build": "npm run build:vite && npm run build:electron && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "idb": "^8.0.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill": "^2.0.0",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.mario.requiem",
    "productName": "Requiem",
    "asar": false,
    "directories": {
      "buildResources": "src/build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "src/build/icon.ico"
    },
    "mac": {
      "icon": "src/build/icon.icns"
    },
    "linux": {
      "icon": "src/build/icon.png"
    }
  }
}
